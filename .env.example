# =============================================
# Supabase PostgreSQL
# =============================================
DB_HOST=db.XXXXXXXXXXXX.supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-supabase-password
DB_NAME=postgres

# =============================================
# JWT (min 16 chars each)
# =============================================
JWT_ACCESS_KEY=your_jwt_access_secret_here_min16chars
JWT_REFRESH_KEY=your_jwt_refresh_secret_here_min16chars

# =============================================
# Email (nodemailer / Gmail App Password)
# =============================================
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# =============================================
# Server
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# Redis (optional - degrades gracefully if missing)
# =============================================
REDIS_URL=redis://localhost:6379

# =============================================
# RabbitMQ (optional - degrades gracefully if missing)
# =============================================
RABBITMQ_URL=amqp://localhost
